{
  "cours": {
    "introduction": {
      "titre": "Introduction – Ingénierie des besoins",
      "contenu": "Ce module vise à maîtriser l'analyse du besoin et la construction d'un Cahier des Charges Fonctionnel (CDCF). Il s'inscrit dans le parcours Ingénierie des Besoins et prépare à la formalisation rigoureuse des attentes du client, des contraintes et des fonctions de service."
    },
    "sections": [
      {
        "id": "formulation-besoin",
        "titre": "Formulation du besoin",
        "couleur": "violet",
        "contenu": "La formulation du besoin consiste à exprimer clairement ce que le client attend du produit ou du système, sans présumer de la solution technique. On distingue le besoin fondamental, les besoins secondaires et les contraintes. L'objectif est de répondre à la question : « À quoi doit servir le produit ? »."
      },
      {
        "id": "bete-cornes-pieuvre",
        "titre": "Bête à cornes & Diagramme Pieuvre",
        "couleur": "rose",
        "contenu": "La bête à cornes permet de préciser le besoin en répondant à trois questions : À qui le produit rend-il service ? Sur quoi agit-il ? Dans quel but ? Le diagramme pieuvre, lui, identifie les fonctions de service et les contraintes en reliant le produit à son environnement (acteurs, éléments, milieux)."
      },
      {
        "id": "cdcf",
        "titre": "Cahier des Charges Fonctionnel (CDCF)",
        "couleur": "vert",
        "contenu": "Le CDCF formalise les fonctions de service (FS) et les fonctions contraintes (FC) sous forme de tableau. Chaque fonction est associée à des critères d'appréciation, des niveaux exigés et des flexibilités. Le CDCF est un document contractuel entre le client et le concepteur."
      },
      {
        "id": "deroulement-seance",
        "titre": "Déroulement de la séance",
        "couleur": "ambre",
        "contenu": "La séance se déroule en quatre temps : 1) Rappel des notions d'ingénierie des besoins, 2) Analyse du besoin à partir d'un cas d'étude, 3) Construction de la bête à cornes et du diagramme pieuvre, 4) Élaboration du CDCF et bilan."
      }
    ],
